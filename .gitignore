reports/report.html
logs/test_execution_*.log
*.png
*.jpg
*.jpeg

# IDE y editores
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store

# Archivos del sistema
Thumbs.db
.env
.env.local

# Archivos temporales
*.tmp
*.temp
*.bak

# Dependencias
*.lock
poetry.lock
