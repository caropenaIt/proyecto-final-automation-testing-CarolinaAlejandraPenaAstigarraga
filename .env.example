# ==============================================================================
# ARCHIVO DE EJEMPLO .env (Configuración Personalizada)
# ==============================================================================
# 
# Copia este archivo a .env y personaliza según necesites
# El archivo .env está en .gitignore para no exponer datos sensibles
#

# ==============================================================================
# CONFIGURACIÓN DE SAUCEDEMO
# ==============================================================================
SAUCEDEMO_URL=https://www.saucedemo.com/
SAUCEDEMO_USER=standard_user
SAUCEDEMO_PASSWORD=secret_sauce

# Opciones de Selenium
SELENIUM_HEADLESS=false
SELENIUM_TIMEOUT=10
SELENIUM_BROWSER=chrome

# ==============================================================================
# CONFIGURACIÓN DE API
# ==============================================================================
API_BASE_URL=https://jsonplaceholder.typicode.com
API_TIMEOUT=5

# ==============================================================================
# CONFIGURACIÓN DE LOGGING
# ==============================================================================
LOG_LEVEL=DEBUG
LOG_DIR=logs
REPORT_DIR=reports

# ==============================================================================
# CONFIGURACIÓN DE EJECUCIÓN
# ==============================================================================
RUN_HEADLESS=false
SCREENSHOT_ON_FAILURE=true
PARALLEL_EXECUTION=false
